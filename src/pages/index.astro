---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout client="maintenance">
  <section style="
    min-height: 100vh;
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 2rem;
    text-align: center;
  ">
    <div style="max-width: 600px;">
      <h1 style="
        font-size: 3rem;
        margin: 0 0 1rem;
        color: var(--elec, #0ea5e9);
      ">
        Maintenance
      </h1>
      <p style="
        font-size: 1.25rem;
        margin: 1rem 0 2rem;
        color: var(--text-secondary, #666);
      ">
        Le site est temporairement hors ligne pour maintenance.
      </p>
      <p style="
        margin: 1.5rem 0;
        color: var(--text-secondary, #666);
        line-height: 1.6;
      ">
        Nous revenir très prochainement. Pour toute urgence, contactez-moi via
        <a href="https://www.linkedin.com/in/willie-leroux-docone/" target="_blank" rel="noopener" style="color: var(--elec, #0ea5e9); text-decoration: none;">LinkedIn</a>.
      </p>
      <div style="
        margin-top: 3rem;
        padding-top: 2rem;
        border-top: 1px solid rgba(0, 0, 0, 0.1);
        font-size: 0.875rem;
        color: var(--text-tertiary, #999);
      ">
        <p>Willie Leroux — Flux documentaires</p>
      </div>
    </div>
  </section>
</BaseLayout>
