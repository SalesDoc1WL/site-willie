---
import { getCollection } from 'astro:content';
import BaseLayout from '../layouts/BaseLayout.astro';
import { url, CALENDLY } from '../lib/url.js';

const expertises = (await getCollection('expertises')).sort((a, b) => a.data.ordre - b.data.ordre);
const secteurs = (await getCollection('secteurs')).sort((a, b) => a.data.ordre - b.data.ordre);
const veille = (await getCollection('veille', ({ data }) => !data.draft))
  .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf())
  .slice(0, 6);

// Vignette par article (photos libres de droit, traitées pour le site)
const ART_THUMB = {
  'bpo-courrier-cout-cache': 'art-bpo.jpg',
  'nf544-copie-fidele': 'art-nf544.jpg',
  'ged-vs-sae': 'art-gedsae.jpg',
  'nf461-durees-conservation': 'art-nf461.jpg',
  'ere-lre-recommande-electronique': 'art-ere.jpg',
  'dematerialiser-courrier-collectivite': 'art-collectivite.jpg',
};
const thumb = (slug) => `/img/home/${ART_THUMB[slug] || 'numerisation.jpg'}`;
const fmtMois = (d) => d.toLocaleDateString('fr-FR', { year: 'numeric', month: 'short' });
const fmtNum = (n) => n.toLocaleString('fr-FR');

const figures = [
  { to: 6, suffix: '', dur: 1500, lab: "expertises couvertes, du courrier entrant à l'archivage à valeur probante" },
  { to: 4, suffix: '', dur: 1500, lab: 'normes clés maîtrisées : NF 544, NF 461, eIDAS, RGPD' },
  { to: 100, suffix: ' %', dur: 1500, lab: 'des étapes tracées, horodatées et opposables' },
];

const normes = ['NF 544', 'NF 461', 'NF K11-112', 'ISO 9001', 'ISO 27001', 'HDS', 'eIDAS', 'RGPD'];

const feat = veille[0];
const restVeille = veille.slice(1);

// Web3Forms : retour sur la page après envoi (mode sans-JS)
const redirectUrl = new URL(url('/?envoye=1'), Astro.site).href + '#contact';

const jsonld = {
  '@context': 'https://schema.org',
  '@type': 'ProfessionalService',
  '@id': new URL('#service', Astro.site).href,
  name: 'Willie Leroux — Flux documentaires',
  description: "Ingénieur d'affaires, spécialiste de l'éditique et de la communication multimodale : BPO courrier, numérisation NF 544, archivage NF 461, recommandé électronique eIDAS, GED, éditique.",
  url: Astro.url.href,
  email: 'wleroux@docone.fr',
  areaServed: { '@type': 'Country', name: 'France' },
  address: { '@type': 'PostalAddress', addressLocality: 'Mérignac', addressRegion: 'Nouvelle-Aquitaine', addressCountry: 'FR' },
  founder: { '@type': 'Person', name: 'Willie Leroux', jobTitle: "Ingénieur d'affaires", worksFor: { '@type': 'Organization', name: 'DocOne' }, sameAs: ['https://www.linkedin.com/in/willie-leroux-docone/'] },
  knowsAbout: ['BPO courrier entrant', 'Numérisation NF 544', 'Archivage électronique NF 461', 'Recommandé électronique eIDAS', 'GED', 'Éditique'],
};
---
<BaseLayout client="home" jsonld={jsonld}>

  <!-- ============ MINI-NAV LATÉRALE ============ -->
  <nav class="snav" id="snav" aria-label="Sections">
    <span class="snav__item" data-go="#dossier"><span class="snav__lab">Le constat</span><span class="snav__dot"></span></span>
    <span class="snav__item" data-go="#flux"><span class="snav__lab">Le flux entrant</span><span class="snav__dot"></span></span>
    <span class="snav__item" data-go="#sortant"><span class="snav__lab">Éditique &amp; sortant</span><span class="snav__dot"></span></span>
    <span class="snav__item" data-go="#expertises"><span class="snav__lab">Expertises</span><span class="snav__dot"></span></span>
    <span class="snav__item" data-go="#secteurs"><span class="snav__lab">Secteurs</span><span class="snav__dot"></span></span>
    <span class="snav__item" data-go="#resultats"><span class="snav__lab">Cadre de confiance</span><span class="snav__dot"></span></span>
    <span class="snav__item" data-go="#veille"><span class="snav__lab">Veille</span><span class="snav__dot"></span></span>
    <span class="snav__item" data-go="#apropos"><span class="snav__lab">À propos</span><span class="snav__dot"></span></span>
    <span class="snav__item" data-go="#contact"><span class="snav__lab">Contact</span><span class="snav__dot"></span></span>
  </nav>

  <!-- ============ HERO ============ -->
  <section class="hero hero--portrait" id="top">
    <div class="wrap hero__in">
      <div class="hero__text">
        <span class="overline overline--elec reveal">Confiance numérique · de bout en bout</span>
        <h1 class="reveal">La valeur juridique ne se décrète pas. Elle se <em>prouve</em>.</h1>
        <p class="hero__lead reveal">J'aide les directions d'ETI, de PME et d'organismes publics à industrialiser le traitement de leurs documents, du courrier entrant jusqu'à l'archivage à valeur probante. Chaque maillon est tracé, horodaté et opposable.</p>
        <div class="hero__cta reveal">
          <a class="btn btn--elec" href={CALENDLY} target="_blank" rel="noopener">Réserver mon diagnostic <span class="arr">→</span></a>
          <a class="btn btn--ghost-dark" href="#expertises">Voir les six expertises</a>
        </div>
      </div>
      <div class="hero__media reveal">
        <div class="hero__ph"><img src={url('/img/home/willie-hero.png')} width="380" height="380" alt="Willie Leroux" /></div>
        <span class="hero__ring"></span>
        <span class="hero__pill"><b>Willie Leroux</b><span>Ingénieur d'affaires chez DocOne</span></span>
      </div>
      <div class="hero__figures reveal">
        {figures.map((f) => (
          <div class="fig">
            <div class="fig__n"><span class="count" data-to={f.to} data-dur={f.dur}>{fmtNum(f.to)}</span>{f.suffix && <i>{f.suffix}</i>}</div>
            <div class="fig__l">{f.lab}</div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- ============ CHIFFRE OBSÉDANT ============ -->
  <section class="obsess" id="constat">
    <span class="obsess__ghost" aria-hidden="true">11</span>
    <div class="wrap obsess__in">
      <div class="obsess__num">
        <div class="obsess__big reveal"><span class="count" data-to="11" data-dur="1600">11</span><i>jours</i></div>
        <p class="obsess__lab reveal">avant qu'un courrier entrant, traité à la main, soit réellement pris en compte.</p>
        <div class="obsess__goal reveal"><span class="count" data-to="1" data-dur="1800">1</span><span>jour ou moins, une fois le flux remis sous contrôle.</span></div>
      </div>
      <div class="obsess__text">
        <h2 class="reveal">Onze jours, c'est le temps que vous ne <em>voyez pas</em>.</h2>
        <p class="reveal">Un pli ouvert à la main, ressaisi, photocopié, classé. À chaque étape, du temps s'accumule et la valeur juridique du document s'efface. Mon rôle est de rendre ce délai visible, puis de le réduire, sans démonstration produit et sans engagement.</p>
      </div>
    </div>
  </section>

  <!-- ============ DOSSIER · LE CONSTAT ============ -->
  <section class="band" id="dossier">
    <img class="band__img" src={url('/img/home/archives.jpg')} alt="Rayonnages d'archives — registres et dossiers papier" loading="lazy" />
    <div class="band__scrim"></div>
    <div class="wrap band__in">
      <div class="band__head reveal">
        <span class="band__label">Dossier</span>
        <span class="band__no">N<sup>o</sup> 01</span>
      </div>
      <div class="band__body">
        <span class="overline overline--elec reveal">Le constat</span>
        <h2 class="reveal">Des kilomètres de documents, encore au rythme du papier.</h2>
        <p class="reveal">Un pli ouvert à la main, ressaisi, classé. Le temps file et la valeur juridique s'efface, sans que personne ne le voie passer.</p>
        <a class="btn btn--light reveal" href="#flux">Suivre le parcours <span class="arr">→</span></a>
      </div>
      <ul class="band__frictions reveal">
        <li><span class="band__fno">01</span> Ressaisi à la main, plusieurs fois</li>
        <li><span class="band__fno">02</span> Classé quelque part, rarement retrouvé</li>
        <li><span class="band__fno">03</span> Sans valeur juridique garantie</li>
      </ul>
    </div>
  </section>

  <!-- ============ LE VOYAGE DU DOCUMENT (séquence entrante) ============ -->
  <section class="jintro" id="flux">
    <div class="wrap">
      <span class="overline overline--elec reveal">Le parcours d'un document · faites défiler</span>
      <h2 class="reveal">Du pli papier à l'archive opposable. <em>Un seul flux</em>, sous contrôle.</h2>
      <p class="jintro__lead reveal">Chaque étape est normée, tracée et réversible. Suivez un document qui entre, se transforme et finit scellé à valeur probante, pendant que le délai fond.</p>
    </div>
  </section>

  <section class="journey">
    <div class="journey__sticky" data-stage="0">
      <div class="jindex">01</div>
      <div class="wrap journey__grid">
        <div class="jpanel">
          <div class="jpanel__steps">
            <div class="jstep" data-s="0">
              <span class="jstep__no">ÉTAPE 01 / 04</span>
              <h3 class="jstep__t">Réception</h3>
              <p class="jstep__d">Le pli arrive, physique ou numérique. Il est tracé et horodaté dès son entrée.</p>
              <span class="jstep__chip"><span class="chip">BPO</span></span>
            </div>
            <div class="jstep" data-s="1">
              <span class="jstep__no">ÉTAPE 02 / 04</span>
              <h3 class="jstep__t">Numérisation</h3>
              <p class="jstep__d">Copie fidèle, juridiquement opposable. L'original papier peut être détruit.</p>
              <span class="jstep__chip"><span class="chip">NF 544</span></span>
            </div>
            <div class="jstep" data-s="2">
              <span class="jstep__no">ÉTAPE 03 / 04</span>
              <h3 class="jstep__t">Circulation</h3>
              <p class="jstep__d">Le document vit : indexé, partagé, accessible aux bonnes personnes.</p>
              <span class="jstep__chip"><span class="chip">GED</span></span>
            </div>
            <div class="jstep" data-s="3">
              <span class="jstep__no">ÉTAPE 04 / 04</span>
              <h3 class="jstep__t">Archivage</h3>
              <p class="jstep__d">Conservé à valeur probante, scellé pour toute la durée légale.</p>
              <span class="jstep__chip"><span class="chip">NF 461</span></span>
            </div>
          </div>
          <div class="jmetrics">
            <div class="jmetric">
              <span class="jmetric__v is-elec" data-metric data-from="11" data-to="1" data-dec="1">11,0<i>jours</i></span>
              <span class="jmetric__l">Délai moyen de prise en compte</span>
            </div>
            <div class="jmetric">
              <span class="jmetric__v" data-metric data-from="0" data-to="100" data-dec="0">0<i>%</i></span>
              <span class="jmetric__l">Valeur probante sécurisée</span>
            </div>
          </div>
          <div class="jrail">
            <div class="jrail__track"><span class="jrail__fill"></span></div>
            <div class="jrail__nodes">
              <span class="jnode"><b></b>Réception</span>
              <span class="jnode"><b></b>Numérisation</span>
              <span class="jnode"><b></b>Circulation</span>
              <span class="jnode"><b></b>Archivage</span>
            </div>
          </div>
        </div>
        <div class="docstage">
          <div class="doc">
            <div class="sheet">
              <div class="sheet__bar s"></div><div class="sheet__bar"></div><div class="sheet__bar s"></div>
              <div class="sheet__bar g"></div><div class="sheet__sp"></div><div class="sheet__bar s"></div><div class="sheet__bar"></div>
            </div>
            <div class="layer layer--s0 layer--mail"><span class="flap"></span><span class="stamp"></span></div>
            <div class="layer layer--s1 layer--scan"><span class="grid"></span><span class="beam"></span><span class="dseal">NF 544</span></div>
            <div class="layer layer--s2 layer--share">
              <span class="ghost g2"></span><span class="ghost g1"></span>
              <span class="node n1">↗</span><span class="node n2">↘</span><span class="node n3">↙</span>
            </div>
            <div class="layer layer--s3 layer--archive"><span class="vault"></span><span class="shield"></span><span class="dseal">NF 461</span></div>
          </div>
        </div>
      </div>
      <div class="jcue"><span>Faites défiler</span><span class="jcue__bar"></span></div>
    </div>
  </section>

  <!-- ============ TRANSITION ============ -->
  <section class="hinge">
    <div class="wrap hinge__in">
      <span class="hinge__line"></span>
      <p class="hinge__txt">Le document est entré, traité, archivé. <em>Et maintenant, il repart.</em></p>
      <span class="hinge__arrow">↓</span>
    </div>
  </section>

  <!-- ============ LE DOCUMENT REPART (séquence sortante) ============ -->
  <section class="jintro jintro--light" id="sortant">
    <div class="wrap">
      <span class="overline reveal">Le document repart · faites défiler</span>
      <h2 class="reveal">Composé, cacheté, signé, remis. Et <em>opposable</em>.</h2>
      <p class="jintro__lead reveal">Le courrier sortant suit le chemin inverse : généré sur mesure, scellé d'un cachet 2D-Doc, signé électroniquement, puis remis en recommandé eIDAS, sans délai postal.</p>
    </div>
  </section>

  <section class="journey journey--light">
    <div class="journey__sticky" data-stage="0">
      <div class="jindex">01</div>
      <div class="wrap journey__grid">
        <div class="jpanel">
          <div class="jpanel__steps">
            <div class="jstep" data-s="0">
              <span class="jstep__no">ÉTAPE 01 / 04</span>
              <h3 class="jstep__t">Éditique</h3>
              <p class="jstep__d">Le document est généré et personnalisé : relevé, courrier de gestion, contrat.</p>
              <span class="jstep__chip"><span class="chip">ÉDITIQUE</span></span>
            </div>
            <div class="jstep" data-s="1">
              <span class="jstep__no">ÉTAPE 02 / 04</span>
              <h3 class="jstep__t">Cachet 2D-Doc</h3>
              <p class="jstep__d">Un cachet électronique scelle l'origine et garantit l'intégrité du document.</p>
              <span class="jstep__chip"><span class="chip">2D-Doc</span></span>
            </div>
            <div class="jstep" data-s="2">
              <span class="jstep__no">ÉTAPE 03 / 04</span>
              <h3 class="jstep__t">Signature électronique</h3>
              <p class="jstep__d">Signé avec la même portée juridique qu'une signature manuscrite.</p>
              <span class="jstep__chip"><span class="chip">eIDAS</span></span>
            </div>
            <div class="jstep" data-s="3">
              <span class="jstep__no">ÉTAPE 04 / 04</span>
              <h3 class="jstep__t">Recommandé électronique</h3>
              <p class="jstep__d">Remis en LRE : preuve de dépôt et de réception, opposable, sans délai postal.</p>
              <span class="jstep__chip"><span class="chip">ERE / LRE</span></span>
            </div>
          </div>
          <div class="jmetrics">
            <div class="jmetric">
              <span class="jmetric__v is-elec" data-metric data-from="72" data-to="0" data-dec="0">72<i>h</i></span>
              <span class="jmetric__l">Délai d'acheminement (vs courrier postal)</span>
            </div>
            <div class="jmetric">
              <span class="jmetric__v" data-metric data-from="0" data-to="100" data-dec="0">0<i>%</i></span>
              <span class="jmetric__l">Preuve de remise opposable</span>
            </div>
          </div>
          <div class="jrail">
            <div class="jrail__track"><span class="jrail__fill"></span></div>
            <div class="jrail__nodes">
              <span class="jnode"><b></b>Éditique</span>
              <span class="jnode"><b></b>Cachet 2D-Doc</span>
              <span class="jnode"><b></b>Signature</span>
              <span class="jnode"><b></b>Recommandé</span>
            </div>
          </div>
        </div>
        <div class="docstage">
          <div class="doc">
            <div class="sheet">
              <div class="sheet__bar s"></div><div class="sheet__bar"></div><div class="sheet__bar s"></div>
              <div class="sheet__bar g"></div><div class="sheet__sp"></div><div class="sheet__bar s"></div><div class="sheet__bar"></div>
            </div>
            <div class="layer layer--s0 layer--compose"><span class="ln l1"></span><span class="ln l2"></span><span class="caret"></span><span class="dseal">ÉDITIQUE</span></div>
            <div class="layer layer--s1 layer--seal2d"><span class="dm"></span><span class="dseal">2D-Doc</span></div>
            <div class="layer layer--s2 layer--sign"><span class="sigline"></span><span class="sig"></span><span class="check">✓</span><span class="dseal">Signé · eIDAS</span></div>
            <div class="layer layer--s3 layer--send"><span class="trail"></span><span class="plane"></span><span class="dseal">Remis · LRE</span></div>
          </div>
        </div>
      </div>
      <div class="jcue"><span>Faites défiler</span><span class="jcue__bar"></span></div>
    </div>
  </section>

  <!-- ============ EXPERTISES ============ -->
  <section class="exp" id="expertises">
    <div class="wrap">
      <div class="eyebrow eyebrow--elec"><span class="no">01</span> Six leviers, du courrier entrant à la confiance numérique</div>
      <div class="exp__list">
        {expertises.map((e, i) => (
          <a class="exp__row" href={url(`/expertises/${e.slug}`)}>
            <span class="exp__no">{String(i + 1).padStart(2, '0')}</span>
            <span class="exp__body">
              <span class="exp__norme">{e.data.norme}</span>
              <span class="exp__t">{e.data.titre}</span>
              <span class="exp__d">{e.data.resume}</span>
            </span>
            <span class="exp__arr">→</span>
          </a>
        ))}
      </div>
    </div>
  </section>

  <!-- ============ SECTEURS ============ -->
  <section class="sect" id="secteurs">
    <div class="wrap">
      <div class="eyebrow"><span class="no">02</span> Des contraintes propres à chaque métier</div>
      <div class="sect__grid">
        {secteurs.map((s) => (
          <a class="vig" href={url(`/secteurs/${s.slug}`)}>
            <b>{s.data.titre}</b>
            <span>{s.data.resume}</span>
          </a>
        ))}
      </div>
    </div>
  </section>

  <!-- ============ CADRE DE CONFIANCE ============ -->
  <section class="res" id="resultats">
    <div class="wrap">
      <div class="eyebrow"><span class="no">03</span> Un cadre normatif, pas des promesses</div>
      <h2>Chaque étape s'appuie sur une norme opposable</h2>
      <p style="max-width:60ch;margin-top:12px;">La valeur juridique de vos documents ne se décrète pas : elle repose sur des référentiels précis. Voici le cadre sur lequel je m'appuie pour sécuriser la numérisation, l'archivage, la signature et le recommandé électronique.</p>
      <div style="display:flex;flex-wrap:wrap;gap:10px;margin-top:28px;">
        {normes.map((n) => <span class="chip">{n}</span>)}
      </div>
      <div class="sec-head-cta" style="margin-top:36px;"><a class="btn btn--secondary" href={CALENDLY} target="_blank" rel="noopener">Réserver mon diagnostic <span class="arr">→</span></a></div>
    </div>
  </section>

  <!-- ============ VEILLE ============ -->
  <section class="veille" id="veille">
    <div class="wrap">
      <div class="eyebrow"><span class="no">04</span> Veille · ce que je lis et ce que j'écris</div>
      <div class="veille__layout">
        {feat && (
          <a class="vfeat" href={url(`/veille/${feat.slug}`)}>
            <div class="vfeat__thumb"><img src={url(thumb(feat.slug))} alt="" loading="lazy" /><span class="vfeat__cat">{feat.data.categorie}</span></div>
            <div class="vfeat__body">
              <span class="vfeat__kicker">À la une</span>
              <span class="vrow__meta">{fmtMois(feat.data.pubDate)}</span>
              <b class="vfeat__t">{feat.data.titre}</b>
              <span class="vfeat__d">{feat.data.description}</span>
              <span class="art__more">Lire l'article <span class="arr">→</span></span>
            </div>
          </a>
        )}
        <ol class="vlist">
          {restVeille.map((a, i) => (
            <li><a class="vrow" href={url(`/veille/${a.slug}`)}>
              <span class="vrow__no">{String(i + 2).padStart(2, '0')}</span>
              <span class="vrow__main">
                <span class="vrow__meta">{fmtMois(a.data.pubDate)} · {a.data.categorie}</span>
                <b class="vrow__t">{a.data.titre}</b>
              </span>
              <span class="vrow__arr">→</span>
            </a></li>
          ))}
        </ol>
      </div>
      <div class="sec-head-cta" style="margin-top:36px;"><a class="btn btn--secondary" href={url('/veille')}>Toute la veille <span class="arr">→</span></a></div>
    </div>
  </section>

  <!-- ============ À PROPOS ============ -->
  <section class="about" id="apropos">
    <div class="wrap about__solo">
      <span class="overline reveal">À propos</span>
      <h2 class="reveal">Je ne vends pas un logiciel. Je remets vos documents <em>sous contrôle</em>.</h2>
      <p class="reveal">Ingénieur d'affaires en flux documentaires, j'accompagne les directions d'ETI, de PME et d'organismes publics. Mon métier : rendre visible le temps que vos documents perdent, puis le réduire, du courrier entrant jusqu'à l'archivage à valeur probante.</p>
      <p class="reveal">Pas de démonstration produit, pas de jargon, pas d'engagement. On regarde votre flux réel, et on agit là où ça compte.</p>
      <div class="about__sign reveal">
        <div class="nm">Willie Leroux</div>
        <div class="ro">Ingénieur d'affaires · DocOne · Mérignac</div>
      </div>
      <div class="about__cta reveal">
        <a class="btn btn--primary" href={CALENDLY} target="_blank" rel="noopener">Réserver un échange <span class="arr">→</span></a>
        <a class="btn btn--ghost-dark" href="#contact">M'écrire</a>
      </div>
    </div>
  </section>

  <!-- ============ DIAGNOSTIC ============ -->
  <section class="diag">
    <span class="diag__ghost" aria-hidden="true">30'</span>
    <div class="wrap diag__in">
      <span class="overline reveal">Diagnostic de maturité documentaire</span>
      <h2 class="reveal">Trente minutes pour voir où vos documents perdent du temps.</h2>
      <p class="reveal">Sans démonstration produit, sans engagement. On regarde ensemble comment vos documents entrent, circulent et sont conservés, et ce qu'il faudrait remettre sous contrôle en priorité.</p>
      <div class="diag__cta reveal">
        <a class="btn btn--light" href={CALENDLY} target="_blank" rel="noopener">Réserver mon créneau <span class="arr">→</span></a>
        <a class="btn btn--ghost-dark" href="#contact" style="border-color: rgba(255,255,255,.6)">Me décrire votre besoin</a>
      </div>
    </div>
  </section>

  <!-- ============ CONTACT ============ -->
  <section class="contact" id="contact">
    <div class="wrap contact__in">
      <div class="contact__intro">
        <span class="overline overline--elec reveal">Échangeons</span>
        <h2 class="reveal">Décrivez-moi votre flux. Je vous réponds <em>sous 48&#8239;h</em>.</h2>
        <p class="contact__lead reveal">Un mot sur vos volumes, vos contraintes, le métier concerné. Pas besoin d'être au point : c'est justement l'objet de l'échange.</p>
        <dl class="contact__meta reveal">
          <div><dt>Basé à</dt><dd><a class="map-link" href="https://www.google.com/maps/search/?api=1&amp;query=19+Rue+Nicolas+Leblanc+33700+M%C3%A9rignac" target="_blank" rel="noopener">19 Rue Nicolas Leblanc, 33700 Mérignac</a></dd></div>
          <div><dt>Interventions</dt><dd>France entière, à distance ou sur site</dd></div>
          <div><dt>LinkedIn</dt><dd><a class="li-link" href="https://www.linkedin.com/in/willie-leroux-docone/" target="_blank" rel="noopener" aria-label="Profil LinkedIn de Willie Leroux"><svg class="li-ico" viewBox="0 0 24 24" width="18" height="18" aria-hidden="true"><path fill="currentColor" d="M20.45 20.45h-3.56v-5.57c0-1.33-.02-3.04-1.85-3.04-1.85 0-2.14 1.45-2.14 2.94v5.67H9.34V9h3.42v1.56h.05c.48-.9 1.64-1.85 3.37-1.85 3.6 0 4.27 2.37 4.27 5.46v6.28zM5.34 7.43a2.07 2.07 0 1 1 0-4.14 2.07 2.07 0 0 1 0 4.14zM7.12 20.45H3.56V9h3.56v11.45zM22.22 0H1.77C.79 0 0 .77 0 1.73v20.54C0 23.22.79 24 1.77 24h20.45c.98 0 1.78-.78 1.78-1.73V1.73C24 .77 23.2 0 22.22 0z"/></svg><span>willie-leroux-docone</span></a></dd></div>
        </dl>
      </div>
      <div id="form-success" class="form-success reveal" hidden>
        <strong>Message envoyé.</strong> Merci, je vous réponds rapidement. Vous pouvez aussi <a href={CALENDLY} target="_blank" rel="noopener">réserver un créneau</a>.
      </div>
      <form id="contact-form" class="form reveal" action="https://api.web3forms.com/submit" method="POST">
        <input type="hidden" name="access_key" value="bbb1062b-8665-41de-b30a-fe9d1d44e3de" />
        <input type="hidden" name="subject" value="Nouveau contact — site flux documentaires" />
        <input type="hidden" name="from_name" value="Site Willie Leroux" />
        <input type="hidden" name="redirect" value={redirectUrl} />
        <input type="checkbox" name="botcheck" class="hp" tabindex="-1" autocomplete="off" aria-hidden="true" style="display:none" />
        <div class="row">
          <div class="field"><label for="f-nom">Nom</label><input id="f-nom" name="nom" type="text" autocomplete="name" placeholder="Votre nom" required /></div>
          <div class="field"><label for="f-org">Organisation</label><input id="f-org" name="organisation" type="text" autocomplete="organization" placeholder="Société, collectivité…" /></div>
        </div>
        <div class="row">
          <div class="field"><label for="f-mail">Email</label><input id="f-mail" name="email" type="email" autocomplete="email" placeholder="vous@organisation.fr" required /></div>
          <div class="field"><label for="f-sec">Secteur</label>
            <select id="f-sec" name="secteur">
              <option>Banque</option><option>Secteur public</option><option>Assurance</option>
              <option>Protection sociale</option><option>Courtage</option><option>Collectivités</option><option>Autre</option>
            </select>
          </div>
        </div>
        <div class="field"><label for="f-msg">Votre besoin</label><textarea id="f-msg" name="message" placeholder="Décrivez en quelques lignes le flux concerné, vos volumes et vos contraintes." required></textarea></div>
        <div class="form__foot">
          <button class="btn btn--elec" type="submit">Envoyer ma demande <span class="arr">→</span></button>
          <p class="form__note">Vos informations restent confidentielles et ne servent qu'à préparer notre échange.</p>
        </div>
      </form>
    </div>
  </section>

  <script is:inline>
    (function () {
      if (location.search.indexOf('envoye=1') !== -1) {
        var ok = document.getElementById('form-success');
        var f = document.getElementById('contact-form');
        if (ok) ok.hidden = false;
        if (f) f.hidden = true;
      }
      var form = document.getElementById('contact-form');
      if (!form) return;
      form.addEventListener('submit', function (e) {
        e.preventDefault();
        var btn = form.querySelector('button[type=submit]');
        if (btn) { btn.disabled = true; btn.textContent = 'Envoi…'; }
        fetch('https://api.web3forms.com/submit', {
          method: 'POST', headers: { 'Accept': 'application/json' }, body: new FormData(form),
        }).then(function (r) { return r.json(); }).then(function (data) {
          if (data.success) {
            var ok = document.getElementById('form-success');
            if (ok) { ok.hidden = false; ok.scrollIntoView({ behavior: 'smooth', block: 'center' }); }
            form.hidden = true;
          } else { throw new Error(data.message || 'Erreur'); }
        }).catch(function () {
          if (btn) { btn.disabled = false; btn.innerHTML = 'Envoyer ma demande <span class="arr">→</span>'; }
          alert("L'envoi a échoué. Réessayez ou écrivez-moi via LinkedIn / Calendly.");
        });
      });
    })();
  </script>

</BaseLayout>
