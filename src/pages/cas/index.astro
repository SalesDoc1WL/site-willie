---
import { getCollection } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import Breadcrumb from '../../components/Breadcrumb.astro';
import DiagnosticCTA from '../../components/DiagnosticCTA.astro';
import { url } from '../../lib/url.js';
import { SECTEUR_LABELS, EXPERTISE_LABELS, secteurLabel } from '../../lib/labels.js';

const casList = (await getCollection('cas', ({ data }) => !data.draft)).sort((a, b) => a.data.ordre - b.data.ordre);

// Filtres disponibles (uniquement ceux réellement présents)
const secteursPresents = [...new Set(casList.map((c) => c.data.secteur))];
const expertisesPresentes = [...new Set(casList.flatMap((c) => c.data.expertises))];
---
<BaseLayout title="Bibliothèque de cas" description="Cas clients anonymisés en flux documentaires : banque, secteur public, assurance, protection sociale, courtage, collectivités. Volumes, normes et résultats.">
  <Breadcrumb items={[{ label: 'Cas' }]} />
  <header class="page-head">
    <div class="wrap">
      <span class="overline">Bibliothèque de cas</span>
      <h1>Des réalisations, des volumes, des preuves.</h1>
      <p>Cas anonymisés, classés par secteur et par expertise. Filtrez pour trouver une situation proche de la vôtre.</p>
    </div>
  </header>

  <section class="lsec reveal">
    <div class="wrap">
      <div class="filters">
        <span class="gl">Secteur</span>
        <button class="fltchip active" data-filter="secteur" data-value="*" aria-pressed="true">Tous</button>
        {secteursPresents.map((s) => (
          <button class="fltchip" data-filter="secteur" data-value={s} aria-pressed="false">{SECTEUR_LABELS[s] ?? s}</button>
        ))}
      </div>
      <div class="filters" style="margin-top:10px;">
        <span class="gl">Expertise</span>
        <button class="fltchip active" data-filter="expertise" data-value="*" aria-pressed="true">Toutes</button>
        {expertisesPresentes.map((e) => (
          <button class="fltchip" data-filter="expertise" data-value={e} aria-pressed="false">{EXPERTISE_LABELS[e] ?? e}</button>
        ))}
      </div>

      <div class="refs" id="cas-grid" style="margin-top:32px;">
        {casList.map((c) => (
          <a class="ref cas-item" href={url(`/cas/${c.slug}`)} data-secteur={c.data.secteur} data-expertises={c.data.expertises.join(' ')}>
            <span class="tag">{secteurLabel(c.data.secteur)}</span>
            <h3>{c.data.titre}</h3>
            <p>{c.data.resume}</p>
            <span class="more arrow">Lire le cas </span>
          </a>
        ))}
      </div>
      <p id="cas-empty" class="muted" style="display:none;margin-top:24px;">Aucun cas ne correspond à ces filtres.</p>
    </div>
  </section>

  <DiagnosticCTA />
</BaseLayout>

<script is:inline>
  (function () {
    const state = { secteur: '*', expertise: '*' };
    const items = [...document.querySelectorAll('.cas-item')];
    const empty = document.getElementById('cas-empty');
    function apply() {
      let visible = 0;
      items.forEach((el) => {
        const sOk = state.secteur === '*' || el.dataset.secteur === state.secteur;
        const eOk = state.expertise === '*' || (el.dataset.expertises || '').split(' ').includes(state.expertise);
        const show = sOk && eOk;
        el.style.display = show ? '' : 'none';
        if (show) visible++;
      });
      if (empty) empty.style.display = visible === 0 ? '' : 'none';
    }
    document.querySelectorAll('.fltchip[data-filter]').forEach((btn) => {
      btn.addEventListener('click', () => {
        const f = btn.dataset.filter === 'secteur' ? 'secteur' : 'expertise';
        state[f] = btn.dataset.value;
        document.querySelectorAll('.chip[data-filter="' + btn.dataset.filter + '"]').forEach((b) => {
          const on = b === btn;
          b.classList.toggle('active', on);
          b.setAttribute('aria-pressed', String(on));
        });
        apply();
      });
    });
  })();
</script>
