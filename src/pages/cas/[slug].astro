---
import { getCollection } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import Breadcrumb from '../../components/Breadcrumb.astro';
import DiagnosticCTA from '../../components/DiagnosticCTA.astro';
import RelatedList from '../../components/RelatedList.astro';
import { expertiseLabel, secteurLabel } from '../../lib/labels.js';

export async function getStaticPaths() {
  const casList = await getCollection('cas', ({ data }) => !data.draft);
  return casList.map((c) => ({ params: { slug: c.slug }, props: { entry: c } }));
}

const { entry } = Astro.props;
const { Content } = await entry.render();

const expertiseLinks = entry.data.expertises.map((e) => ({ href: `/expertises/${e}`, label: expertiseLabel(e) }));
const secteurLink = [{ href: `/secteurs/${entry.data.secteur}`, label: secteurLabel(entry.data.secteur) }];
---
<BaseLayout title={entry.data.titre} description={entry.data.resume} type="article">
  <Breadcrumb items={[{ label: 'Cas', href: '/cas' }, { label: entry.data.titre }]} />
  <header class="page-head">
    <div class="wrap">
      <span class="overline">{secteurLabel(entry.data.secteur)}</span>
      <h1>{entry.data.titre}</h1>
      <p>{entry.data.resume}</p>
    </div>
  </header>

  {entry.data.chiffres.length > 0 && (
    <section class="lsec reveal">
      <div class="wrap">
        <div class="stats">
          {entry.data.chiffres.map((ch) => (
            <div class="stat-box">
              <div class="num">{ch.valeur}</div>
              <div class="lab">{ch.label}</div>
            </div>
          ))}
        </div>
      </div>
    </section>
  )}

  <section class="lsec reveal">
    <div class="wrap">
      <article class="prose"><Content /></article>
    </div>
  </section>

  <section class="lsec reveal">
    <div class="wrap">
      <RelatedList titre="Expertises mobilisées" links={expertiseLinks} />
      <RelatedList titre="Secteur" links={secteurLink} />
    </div>
  </section>

  <DiagnosticCTA />
</BaseLayout>
