---
import { url, CALENDLY, LINKEDIN, LIEU } from '../lib/url.js';
const annee = 2026;
const expertises = [
  { href: '/expertises/bpo-courrier-entrant', label: 'Courrier entrant (BPO)' },
  { href: '/expertises/numerisation-nf544', label: 'Numérisation NF 544' },
  { href: '/expertises/archivage-electronique-nf461', label: 'Archivage SAE NF 461' },
  { href: '/expertises/recommande-electronique-eidas', label: 'Recommandé électronique' },
  { href: '/expertises/ged-documents-vivants', label: 'GED' },
  { href: '/expertises/editique-confiance', label: 'Éditique & confiance' },
];
const secteurs = [
  { href: '/secteurs/banque', label: 'Banque' },
  { href: '/secteurs/secteur-public', label: 'Secteur public' },
  { href: '/secteurs/assurance', label: 'Assurance' },
  { href: '/secteurs/protection-sociale', label: 'Protection sociale' },
  { href: '/secteurs/courtage', label: 'Courtage' },
  { href: '/secteurs/collectivites', label: 'Collectivités' },
];
---
<footer class="site">
  <div class="wrap">
    <div class="ft-top">
      <span class="liseret" aria-hidden="true"></span>
      <span>
        <span class="nom">Willie Leroux</span><br />
        <span class="sous">Ingénieur d'affaires · éditique &amp; communication multimodale</span>
        <span class="sous" style="opacity:.85">Au sein de DocOne · Mérignac (33), Nouvelle-Aquitaine</span>
      </span>
    </div>

    <div class="ft-cols">
      <div>
        <h4>Expertises</h4>
        {expertises.map((e) => <a href={url(e.href)}>{e.label}</a>)}
      </div>
      <div>
        <h4>Secteurs</h4>
        {secteurs.map((s) => <a href={url(s.href)}>{s.label}</a>)}
      </div>
      <div>
        <h4>Ressources</h4>
        <a href={url('/cas')}>Bibliothèque de cas</a>
        <a href={url('/veille')}>Veille</a>
        <a href={url('/a-propos')}>À propos</a>
        <a href={url('/rss.xml')}>Flux RSS</a>
      </div>
      <div>
        <h4>Contact</h4>
        <a href={CALENDLY} target="_blank" rel="noopener">Réserver 30 min</a>
        <a href={LINKEDIN} target="_blank" rel="noopener">LinkedIn</a>
        <a href={url('/#contact')}>Formulaire</a>
      </div>
    </div>

    <div class="ft-legal">
      <span>© {annee} Willie Leroux — {LIEU}</span>
      <a href={url('/mentions-legales')}>Mentions légales</a>
      <span>Codes inspirés du Système de Design de l'État, sans bloc-marque officiel.</span>
    </div>
  </div>
</footer>
