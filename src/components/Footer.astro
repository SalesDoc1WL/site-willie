---
import { url, CALENDLY } from '../lib/url.js';
const home = (hash) => `${url('/')}${hash}`.replace('//', '/');
const expertises = [
  { href: '/expertises/bpo-courrier-entrant', label: 'Courrier entrant (BPO)' },
  { href: '/expertises/numerisation-nf544', label: 'Copie fidèle NF 544' },
  { href: '/expertises/archivage-electronique-nf461', label: 'Archivage NF 461' },
  { href: '/expertises/recommande-electronique-eidas', label: 'Recommandé eIDAS' },
  { href: '/expertises/ged-documents-vivants', label: 'GED & éditique' },
];
---
<footer class="foot">
  <div class="wrap">
    <div class="foot__in">
      <div class="foot__brand-col">
        <div class="foot__brand"><span class="liseret" aria-hidden="true"></span> Willie Leroux</div>
        <p class="foot__about">Simplifier, automatiser, sécuriser. Ingénieur d'affaires chez DocOne, j'industrialise l'ensemble de votre cycle documentaire, de la numérisation des flux entrants à l'archivage légal à valeur probante. Ce site est mon blog personnel&#8239;: vous y trouverez une veille et des conseils concrets pour moderniser la gestion de vos documents, de l'éditique au numérique.</p>
      </div>
      <div class="foot__col">
        <h4>Expertises</h4>
        <ul>
          {expertises.map((e) => <li><a href={url(e.href)}>{e.label}</a></li>)}
        </ul>
      </div>
      <div class="foot__col">
        <h4>Navigation</h4>
        <ul>
          <li><a href={home('#constat')}>Le constat</a></li>
          <li><a href={home('#flux')}>Le flux</a></li>
          <li><a href={url('/secteurs')}>Secteurs</a></li>
          <li><a href={url('/veille')}>Veille</a></li>
          <li><a href={url('/simulateur')}>Simulateur de coûts</a></li>
          <li><a href={CALENDLY} target="_blank" rel="noopener">Réserver un échange</a></li>
        </ul>
      </div>
    </div>
    <div class="foot__bottom">
      <span>© 2026 Willie Leroux · Ingénieur commercial chez DocOne — Mérignac, Nouvelle-Aquitaine · <a class="map-link" href={url('/mentions-legales')}>Mentions légales</a></span>
      <div class="normes">
        <span>NF 544</span><span>NF 461</span><span>ISO 27001</span><span>HDS</span><span>eIDAS</span><span>RGPD</span>
      </div>
    </div>
  </div>
</footer>
