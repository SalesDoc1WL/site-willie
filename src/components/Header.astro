---
import { url, CALENDLY } from '../lib/url.js';
// Liens d'ancrage vers les sections de l'accueil (fonctionnent depuis toute page).
const home = (hash) => `${url('/')}${hash}`.replace('//', '/');
const nav = [
  { href: home('#constat'), label: 'Le constat' },
  { href: home('#flux'), label: 'Le flux' },
  { href: home('#expertises'), label: 'Expertises' },
  { href: home('#secteurs'), label: 'Secteurs' },
  { href: home('#resultats'), label: 'Cas' },
  { href: home('#veille'), label: 'Veille' },
];
---
<header class="hdr">
  <div class="wrap hdr__in">
    <a class="hdr__brand" href={url('/')} aria-label="Accueil — Willie Leroux">
      <span class="liseret" aria-hidden="true"></span>
      <span>Willie Leroux<small>DocOne · Flux documentaires</small></span>
    </a>
    <nav class="hdr__nav" id="nav" aria-label="Navigation principale">
      {nav.map((n) => <a href={n.href}>{n.label}</a>)}
    </nav>
    <div class="hdr__cta">
      <a class="btn btn--elec" href={CALENDLY} target="_blank" rel="noopener">Échanger 30&#8239;min</a>
      <button class="hdr__burger" id="burger" aria-label="Ouvrir le menu" aria-expanded="false" aria-controls="nav"><span></span><span></span><span></span></button>
    </div>
  </div>
</header>
